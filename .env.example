# Nodus Recept FM — Edge Node Configuration
# Copy this file to .env and edit the values below.

# === Required: Frequencies ===
# Frequencies to monitor in Hz (comma-separated).
# Example: two national simplex + one local repeater
RECEPT_FM_CORE_FREQUENCIES=146520000,146940000,147000000

# === Required: Connectivity (to central Nodus) ===
# Synapse endpoint via Gateway (get an API key from the Nodus admin)
RECEPT_SYNAPSE_ENDPOINT=https://api.nodusalert.ai
RECEPT_SYNAPSE_AUTH_TOKEN=your-api-key-here

# === Whisper (default: bundled CPU container) ===
# The compose file runs a local CPU Whisper container.
# Override to point at a remote GPU Whisper server:
RECEPT_WHISPER_API_URL=http://whisper:8000
# RECEPT_WHISPER_API_URL=http://your-gpu-server:8000

# === Whisper Model (CPU container) ===
# base = fast, good enough for clear FM audio (~1x realtime on modern CPU)
# small = better accuracy, ~3x slower
# medium = best accuracy, ~8x slower — not recommended for CPU
WHISPER_MODEL=base

# === Node Identity ===
# Unique name for this edge node (appears in Synapse/Cortex)
RECEPT_NODE_ID=edge-your-callsign
# Metro area slug (e.g., "phoenix", "omaha") — used for grouping
RECEPT_METRO=

# === Scanner Backend ===
# airband = RTLSDR-Airband simultaneous multi-channel (recommended)
# rtl_fm  = legacy sequential scanner (fallback if airband binary missing)
RECEPT_FM_SCANNER_BACKEND=airband
RECEPT_FM_GAIN=40
RECEPT_FM_SQUELCH_THRESHOLD=30

# === Critical FM Settings ===
# DO NOT change these unless you know what you're doing.
RECEPT_WHISPER_VAD_FILTER=false
RECEPT_FM_HALLUCINATION_FILTER_ENABLED=true
RECEPT_FM_MORSE_DETECTION_ENABLED=true
RECEPT_FM_EXTRACT_CALLSIGNS=true

# === Edge Dashboard ===
# Local web UI at localhost:8073 — works fully offline
RECEPT_DASHBOARD_ENABLED=true
RECEPT_DASHBOARD_PORT=8073

# === Diagnostics (heartbeat health reporting) ===
RECEPT_DIAGNOSTICS_ENDPOINT=https://api.nodusalert.ai
